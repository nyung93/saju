<title>사주팔자 종합 분석 — 하경희 & 최다민</title>

<!-- Google Fonts -->
<link rel="preconnect" href="[https://fonts.googleapis.com](https://fonts.googleapis.com)">
<link rel="preconnect" href="[https://fonts.gstatic.com](https://fonts.gstatic.com)" crossorigin>
<link href="[https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500;600;700;900&family=Noto+Sans+KR:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap](https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500;600;700;900&family=Noto+Sans+KR:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap)" rel="stylesheet">

<style>
:root {
  --bg:     #0c1018;
  --bg2:    #131922;
  --bg3:    #1a2233;
  --surf:   #1f2a40;
  --bdr:    #2a3850;
  --teal:   #5ec4ba;
  --teal-d: #2e9e96;
  --gold:   #e8b84b;
  --gold-d: #b8901a;
  --rose:   #e07878;
  --sage:   #7ec898;
  --sage-d: #3a9460;
  --slate:  #7a90b0;
  --white:  #e8eef8;
  --muted:  #4a5c78;
  --r: 7px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

/* Vercel 배포 시 탭 클릭 후 이동할 때 헤더에 가려지지 않게 설정 */
html {
  scroll-behavior: smooth;
  scroll-padding-top: 80px; 
}
body {
  font-family:'Noto Sans KR',sans-serif;
  background:var(--bg);
  color:var(--white);
  line-height:1.8;
  font-size:15px; 
  margin:0;
  overflow-x: hidden;
}

/* ── TAB SYSTEM ── */
.tab-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(12, 16, 24, 0.95);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--bdr);
  z-index: 1000;
  display: flex;
  justify-content: center;
}
.tab-btn {
  background: none;
  border: none;
  color: var(--muted);
  font-family: 'Noto Sans KR', sans-serif;
  font-size: 15px;
  font-weight: 700;
  padding: 16px 32px;
  cursor: pointer;
  transition: all 0.3s ease;
  border-bottom: 3px solid transparent;
}
.tab-btn:hover { color: var(--white); }
.tab-btn.active {
  color: var(--teal);
  border-bottom: 3px solid var(--teal);
}
.tab-pane {
  display: none;
  padding-top: 56px;
}
.tab-pane.active {
  display: block;
  animation: fadeIn 0.4s ease;
}
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

/* ── HEADER ── */
.hdr{
  background:linear-gradient(155deg,#0c1018 0%,#152040 55%,#0c1018 100%);
  border-bottom:1px solid var(--bdr);
  padding:52px 0 44px;text-align:center;position:relative;overflow:hidden;
}
.hdr::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse at 25% 60%,rgba(94,196,186,.07) 0%,transparent 55%),
    radial-gradient(ellipse at 75% 40%,rgba(232,184,75,.06) 0%,transparent 55%);
}
.hdr-in{position:relative;z-index:1}
.hdr-eyebrow{font-family:'Cormorant Garamond',serif;font-size:11px;letter-spacing:5px;text-transform:uppercase;color:var(--teal);margin-bottom:12px}
.hdr-name{
  font-family:'Noto Serif KR',serif;
  font-size:clamp(34px, 7vw, 58px);font-weight:900;
  background:linear-gradient(130deg,var(--white) 20%,var(--teal) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  letter-spacing:-1px;line-height:1.1;
}
.hdr-meta{margin-top:12px;font-size:13px;color:var(--slate);line-height:2;letter-spacing:.3px}
.hdr-meta strong{color:var(--teal);font-weight:500}
.hdr-alert{
  display:inline-block;margin-top:14px;
  background:rgba(232,184,75,.12);border:1px solid rgba(232,184,75,.3);
  border-radius:20px;padding:5px 18px;font-size:12px;color:var(--gold);
}
.pstrip{display:flex;justify-content:center;gap:12px;margin-top:28px;flex-wrap:wrap}
.pbox{
  background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);
  padding:12px 22px;text-align:center;min-width:86px;transition:border-color .2s;
}
.pbox:hover{border-color:var(--teal)}
.pbox .pl{font-size:10px;color:var(--muted);letter-spacing:2px;margin-bottom:4px}
.pbox .pk{font-family:'Noto Serif KR',serif;font-size:24px;font-weight:700}
.pbox .pj{font-family:'Noto Serif KR',serif;font-size:20px;font-weight:600;color:var(--gold)}
.pbox .ps{font-size:11px;color:var(--muted);margin-top:2px}
.cw{color:#6bc5f0}.cwood{color:#7ec898}.cfire{color:#f08070}.cearth{color:#d4a840}.cmetal{color:#a8b8d8}

/* ── NAV ── */
.nav{background:var(--bg2);border-bottom:1px solid var(--bdr);position:sticky;top:56px;z-index:100}
.nav-sc{max-width:980px;margin:0 auto;padding:0 20px;display:flex;overflow-x:auto;scrollbar-width:none}
.nav-sc::-webkit-scrollbar{display:none}
.nav-sc a{
  color:var(--muted);text-decoration:none;font-size:11px;letter-spacing:1px;
  white-space:nowrap;padding:11px 13px;border-bottom:2px solid transparent;transition:color .2s,border-color .2s;
}
.nav-sc a:hover{color:var(--teal);border-bottom-color:var(--teal)}

/* ── WRAP ── */
.wrap{max-width:980px;margin:0 auto;padding:0 20px 100px}

/* ── CHAPTER ── */
.ch{margin-top:64px;padding-top:32px;border-top:1px solid var(--bdr)}
.ch-ey{font-family:'Cormorant Garamond',serif;font-size:11px;letter-spacing:4px;color:var(--teal);text-transform:uppercase;margin-bottom:6px}
.ch-ti{font-family:'Noto Serif KR',serif;font-size:clamp(20px,3.5vw,28px);font-weight:700;color:var(--white);line-height:1.3}
.ch-ti span{color:var(--teal)}

/* ── SECTION / SUB ── */
.sec{margin-top:34px}
.sec-ti{font-family:'Noto Serif KR',serif;font-size:15px;font-weight:700;color:var(--teal);padding-bottom:6px;border-bottom:1px solid var(--bdr);margin-bottom:14px}
.sub-ti{font-size:13px;font-weight:700;color:var(--gold);margin:16px 0 8px}

/* ── PROSE ── */
p{margin-bottom:10px;line-height:1.9;font-size:14.5px;color:#c0cce0}
p strong{color:var(--white)}

/* ── TABLE ── */
.tw{overflow-x:auto;margin:14px 0}
table{width:100%;border-collapse:collapse;font-size:13.5px}
thead tr{background:var(--bg3)}
thead th{font-family:'Noto Serif KR',serif;color:var(--teal);padding:10px 12px;text-align:center;font-weight:600;border:1px solid var(--bdr);white-space:nowrap}
tbody tr{border-bottom:1px solid var(--bdr)}
tbody tr:nth-child(odd){background:var(--bg2)}
tbody tr:nth-child(even){background:var(--bg3)}
tbody td{padding:9px 12px;border:1px solid var(--bdr);vertical-align:top;line-height:1.65;color:#c0cce0;font-size:13.5px}
td.ctr{text-align:center}
td.bold{font-weight:700;color:var(--white)}
.tg{color:var(--sage);font-weight:700}
.tw2{color:var(--rose);font-weight:700}
.tgo{color:var(--gold);font-weight:700}
.tt{color:var(--teal);font-weight:700}

/* 원국 표 */
.ptbl thead th{background:#0a1220}
.kbig{font-family:'Noto Serif KR',serif;font-size:26px;font-weight:700;text-align:center;padding:14px 8px}
.jbig{font-family:'Noto Serif KR',serif;font-size:22px;font-weight:600;text-align:center;padding:10px 8px;color:var(--gold)}

/* ── BOX ── */
.box{border-radius:var(--r);padding:16px 20px;margin:14px 0;font-size:14px;line-height:1.85}
.box p{font-size:14px;color:#c0cce0}
.box.tl{background:rgba(94,196,186,.08);border-left:3px solid var(--teal)}
.box.go{background:rgba(232,184,75,.07);border-left:3px solid var(--gold)}
.box.ro{background:rgba(224,120,120,.08);border-left:3px solid var(--rose)}
.box.sg{background:rgba(126,200,152,.08);border-left:3px solid var(--sage)}
.box.dk{background:var(--bg3);border-left:3px solid var(--bdr)}
.box strong{color:var(--white)}
.box.tl strong{color:var(--teal)}
.box.go strong{color:var(--gold)}
.box.ro strong{color:var(--rose)}
.box.sg strong{color:var(--sage)}

/* ── BADGE ── */
.badges{display:flex;flex-wrap:wrap;gap:8px;margin:12px 0}
.badge{padding:5px 14px;border-radius:20px;font-size:12.5px;font-weight:500;border:1px solid}
.badge.tl{background:rgba(94,196,186,.1);color:var(--teal);border-color:rgba(94,196,186,.3)}
.badge.go{background:rgba(232,184,75,.1);color:var(--gold);border-color:rgba(232,184,75,.3)}
.badge.ro{background:rgba(224,120,120,.1);color:var(--rose);border-color:rgba(224,120,120,.3)}
.badge.sg{background:rgba(126,200,152,.1);color:var(--sage);border-color:rgba(126,200,152,.3)}
.badge.sl{background:rgba(122,144,176,.1);color:var(--slate);border-color:rgba(122,144,176,.3)}

/* ── DAEUN GRID ── */
.dg{display:grid;grid-template-columns:repeat(auto-fill,minmax(265px,1fr));gap:14px;margin-top:16px}
.dc{background:var(--bg2);border:1px solid var(--bdr);border-radius:var(--r);overflow:hidden}
.dc-hd{background:var(--bg3);padding:11px 14px;display:flex;justify-content:space-between;align-items:center}
.dc-hd.now{background:#162840;border-bottom:2px solid var(--teal)}
.dc-hd.peak{background:#162a1a;border-bottom:2px solid var(--sage)}
.dc-hd.warn{background:#2a1616;border-bottom:2px solid var(--rose)}
.dc-n{font-size:10px;color:var(--muted);letter-spacing:2px}
.dc-nm{font-family:'Noto Serif KR',serif;font-size:19px;font-weight:700;color:var(--white)}
.dc-ag{font-size:11px;color:var(--slate)}
.dc-bd{padding:12px 14px}
.dc-kw{font-size:11px;color:var(--gold);font-weight:700;letter-spacing:1px;margin-bottom:8px}
.dc-row{display:flex;gap:6px;margin-bottom:5px}
.dc-lb{font-size:11px;font-weight:700;color:var(--muted);min-width:44px;padding-top:2px}
.dc-vl{color:#c0cce0;font-size:13px;line-height:1.6;flex:1}

/* ── ZIWEI ── */
.zw-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px;margin-top:14px}
.zw-card{background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);padding:12px 14px}
.zw-title{font-family:'Noto Serif KR',serif;font-size:12px;font-weight:700;color:var(--teal);margin-bottom:6px}
.zw-main{font-family:'Noto Serif KR',serif;font-size:15px;font-weight:700;color:var(--white);margin-bottom:4px}
.zw-good{font-size:11.5px;color:var(--sage)}
.zw-bad{font-size:11.5px;color:var(--rose)}
.zw-note{font-size:11.5px;color:var(--slate)}
.zw-hua{font-size:12px;color:var(--gold);margin-top:2px;font-weight:700}
.zw-special{border-color:var(--rose);background:rgba(224,120,120,.06)}
.zw-best{border-color:var(--sage);background:rgba(126,200,152,.06)}

/* ── QUOTE ── */
blockquote{
  background:var(--bg3);border:1px solid var(--bdr);border-left:3px solid var(--teal);
  border-radius:var(--r);padding:24px 28px;margin:28px 0;
  font-family:'Noto Serif KR',serif;font-size:15.5px;line-height:1.9;position:relative;
}
blockquote::before{
  content:'"';font-family:'Cormorant Garamond',serif;font-size:72px;
  color:var(--teal);position:absolute;top:-8px;left:14px;line-height:1;opacity:.25;
}
blockquote p{color:var(--white);padding-top:6px}
blockquote strong{color:var(--teal)}

/* ── FOOTER ── */
footer{background:var(--bg2);border-top:1px solid var(--bdr);text-align:center;padding:28px 20px;font-size:12px;line-height:1.9;color:var(--muted)}

@media(max-width:600px){
  .pstrip{gap:8px}.pbox{min-width:70px;padding:10px 12px}
  .dg{grid-template-columns:1fr}.zw-grid{grid-template-columns:1fr 1fr}
}
</style>
</head>
